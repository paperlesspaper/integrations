{
  "name": "Finance Snapshot",
  "version": "0.1.0",
  "status": "alpha",
  "description": "Shows a compact snapshot of markets, commodities, crypto, currencies, energy, and selected stocks.",
  "renderPage": "./render.html",
  "icon": "./assets/icon.png",
  "nativeSettings": {
    "color": "light",
    "preset": "balanced",
    "symbols": [
      "GC=F",
      "BTC-USD",
      "EURUSD=X",
      "^GSPC",
      "CL=F",
      "EUR=X"
    ],
    "customSymbols": "",
    "currency": "USD",
    "locale": "en-US",
    "limit": 8,
    "chartRange": "1mo",
    "showChart": true,
    "showSparklines": true,
    "showRangeStats": true,
    "showChange": true,
    "showSource": true
  },
