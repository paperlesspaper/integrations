{
  "name": "Google Calendar",
  "version": "0.2.0",
  "status": "alpha",
  "description": "Displays Google Calendar events supplied by the paperlesspaper host.",
  "renderPage": "./render.html",
  "icon": "./assets/icon.png",
  "timezone": "Europe/Berlin",
  "requiredPermissions": ["googleCalendar"],
  "nativeSettings": {
    "color": "light",
    "view": "agenda",
    "locale": "de-DE",
    "timeZone": "Europe/Berlin",
    "dayRange": 3,
    "maxEvents": 50,
    "highlightToday": false,
    "highlightScale": 1.35,
    "showLocation": true,
    "showEventIcons": true,
    "showEventImages": false
  },
  "configVariants": [
    {
      "color": "light",
      "view": "agenda",
      "locale": "de-DE",
      "timeZone": "Europe/Berlin",
      "dayRange": 3,
      "maxEvents": 8,
      "highlightToday": false,
      "showLocation": true,
      "showEventIcons": true,
      "showEventImages": false,
      "sampleData": true,
      "now": "2026-07-22T08:00:00.000Z",
      "screenshots": {
        "800x480": "./screenshots/google-calendar-light-800x480-landscape.png",
        "480x800": "./screenshots/google-calendar-light-480x800-portrait.png"
      }
    },
    {
      "color": "red-light",
      "view": "week",
      "locale": "en-US",
      "timeZone": "Europe/Berlin",
      "dayRange": 7,
      "maxEvents": 10,
      "highlightToday": true,
      "highlightScale": 1.35,
      "showLocation": true,
      "showEventIcons": true,
      "showEventImages": false,
      "sampleData": true,
      "now": "2026-07-22T08:00:00.000Z",
      "screenshots": {
        "800x480": "./screenshots/google-calendar-highlight-800x480-landscape.png",
        "480x800": "./screenshots/google-calendar-highlight-480x800-portrait.png"
      }
    }
  ],
  "formSchema": {
    "type": "object",
    "properties": {
      "view": {
        "type": "string",
        "title": "View",
        "enum": ["agenda", "day", "three-days", "week", "year"],
        "enumNames": ["Agenda", "Day", "3 Days", "Week", "Year"],
        "default": "agenda"
      },
      "locale": {
        "type": "string",
        "title": "Date locale",
        "description": "BCP 47 locale, for example de-DE or en-US.",
        "default": "de-DE"
      },
      "timeZone": {
        "type": "string",
        "title": "Time zone",
        "description": "IANA time zone, for example Europe/Berlin.",
        "default": "Europe/Berlin"
      },
      "dayRange": {
        "type": "integer",
        "title": "Agenda day range",
        "minimum": 1,
        "maximum": 366,
        "default": 3
      },
      "maxEvents": {
        "type": "integer",
        "title": "Maximum events",
        "minimum": 1,
        "maximum": 200,
        "default": 50
      },
      "highlightToday": {
        "type": "boolean",
        "title": "Highlight today",
        "default": false
      },
      "highlightScale": {
        "type": "number",
        "title": "Today highlight scale",
        "minimum": 1,
        "maximum": 3,
        "step": 0.05,
        "default": 1.35
      },
      "showLocation": {
        "type": "boolean",
        "title": "Show locations",
        "default": true
      },
      "showEventIcons": {
        "type": "boolean",
        "title": "Show event icons",
        "default": true
      },
      "showEventImages": {
        "type": "boolean",
        "title": "Show event images",
        "default": false
      }
    }
  },
  "language": ["en", "de"]
}
