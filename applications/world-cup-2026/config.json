          "CUW",
          "CZE",
          "COD",
          "ECU",
          "EGY",
          "ENG",
          "FRA",
          "GER",
          "GHA",
          "HAI",
          "IRN",
          "IRQ",
          "CIV",
          "JPN",
          "JOR",
          "MEX",
          "MAR",
          "NED",
          "NZL",
          "NOR",
          "PAN",
          "PAR",
          "POR",
          "QAT",
          "KSA",
          "SCO",
          "SEN",
          "RSA",
          "KOR",
          "ESP",
          "SWE",
          "SUI",
          "TUN",
          "TUR",
          "USA",
          "URU",
          "UZB"
        ],
        "default": "SWE"
      },
      "locale": {
        "type": "string",
        "title": "Locale",
        "default": "en-US",
        "description": "BCP 47 locale such as en-US, de-DE, fr-FR, or ja-JP."
      },
      "timeZone": {
        "type": "string",
        "title": "Time zone",
        "enum": [
          "America/Chicago",
          "America/Denver",
          "America/Los_Angeles",
          "America/Mexico_City",
          "America/New_York",
          "America/Toronto",
          "Europe/Berlin",
          "Europe/London",
          "Europe/Madrid",
          "Europe/Paris",
          "Europe/Stockholm",
          "UTC"
        ],
        "default": "Europe/Berlin"
      },
      "highlightGlobalMatches": {
        "type": "boolean",
        "title": "Highlight favorite team globally",
        "default": true
      }
    }
  },
  "language": [
    "en",
    "de",
    "fr",
    "es",
    "it"
  ]
}
