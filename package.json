{
  "name": "paperlesspaper-openintegrations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "screenshots": "node scripts/render-screenshots.mjs",
    "copy:assets": "node scripts/copy-openintegration-assets.mjs",
