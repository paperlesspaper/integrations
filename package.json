    "docker:build": "docker build -t paperlesspaper-openintegrations:latest .",
    "docker:run": "docker run --rm -p 3000:3000 paperlesspaper-openintegrations:latest"
  },
  "dependencies": {
    "@paperlesspaper/openintegration": "0.1.1",
    "express": "^4.19.2"
  }
}
